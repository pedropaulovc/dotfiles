{{/* Evaluated once at `chezmoi init`; writes ~/.config/chezmoi/chezmoi.toml. */}}
{{/* .platform distinguishes native Windows from WSL from native Linux.        */}}
{{/*   - chezmoi.os is "windows" on native Windows, "linux" on both WSL & Linux */}}
{{/*   - WSL is detected by "microsoft" in the kernel osrelease string          */}}
{{- $platform := .chezmoi.os -}}
{{- if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{-   $platform = "wsl" -}}
{{- end -}}

[data]
    platform = {{ $platform | quote }}
    hostname = {{ .chezmoi.hostname | quote }}

# Run .ps1 scripts (e.g. the SolidWorks settings opener) with PowerShell 7.
[interpreters.ps1]
    command = "pwsh"
    args = ["-NoLogo"]
