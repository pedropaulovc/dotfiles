# Merge chezmoi-managed Codex settings into ~/.codex/config.toml.
#
# Codex owns this file at runtime — it rewrites [projects.*] trust, [hooks.state]
# hashes, [marketplaces.*] revisions, and stores the Firecrawl MCP api key in it. So we
# can't manage it as a plain file (chezmoi would clobber those). Instead this script
# runs on `chezmoi apply` whenever the managed settings change, and surgically upserts
# ONLY those keys via tomlkit, leaving every other key — including the secret and all
# machine-local state — byte-for-byte untouched.
#
# The managed settings live in .chezmoitemplates/codex-managed.toml and are injected
# below via includeTemplate (the rendered script stays self-contained, since a
# run_onchange temp script can't read source files). Managed = enforce-present, not
# enforce-absent: dropping a key there stops enforcing it, but won't delete a copy
# Codex already wrote. Edit that file, not ~/.codex/config.toml.
import os, sys

# On the FIRST `chezmoi apply` after this script lands, chezmoi runs it under its default
# .py interpreter (plain `python`) — the regenerated ~/.config/chezmoi config that maps
# .py -> `uv run --with tomlkit` only takes effect on the NEXT run, so a cold machine would
# otherwise need two passes. That default python usually lacks tomlkit; detect it and
# re-exec under uv (which pulls tomlkit on the fly). A sentinel env var prevents an
# infinite re-exec loop if the dependency still can't be satisfied. If uv itself is
# missing, fail with an actionable message instead of a raw FileNotFoundError.
try:
    import tomlkit
except ModuleNotFoundError:
    if os.environ.get("_CODEX_CFG_UV_BOOTSTRAP"):
        raise
    import subprocess
    try:
        done = subprocess.run(
            ["uv", "run", "--with", "tomlkit", "--quiet", "python", os.path.abspath(__file__), *sys.argv[1:]],
            env={**os.environ, "_CODEX_CFG_UV_BOOTSTRAP": "1"},
        )
    except FileNotFoundError:
        print("codex-config: needs uv or tomlkit - install uv: https://astral.sh/uv", file=sys.stderr)
        sys.exit(1)
    sys.exit(done.returncode)

MANAGED = tomlkit.parse('''
{{ includeTemplate "codex-managed.toml" . }}
''')


def upsert(dst, src):
    """Recursively set managed leaves into dst, preserving unmanaged siblings."""
    for key, val in src.items():
        if isinstance(val, dict) and isinstance(dst.get(key), dict):
            upsert(dst[key], val)
        else:
            dst[key] = val


path = os.path.expanduser(sys.argv[1] if len(sys.argv) > 1 else "~/.codex/config.toml")
doc = tomlkit.parse(open(path, encoding="utf-8").read()) if os.path.exists(path) else tomlkit.document()
upsert(doc, MANAGED)
os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path, "w", encoding="utf-8", newline="\n") as f:
    f.write(tomlkit.dumps(doc))
